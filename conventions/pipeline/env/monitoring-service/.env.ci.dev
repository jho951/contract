SERVICE_SHARED_NETWORK=service-backbone-shared

PROMETHEUS_IMAGE=123456789012.dkr.ecr.ap-northeast-2.amazonaws.com/dev-monitoring-service-prometheus:ci
GRAFANA_IMAGE=123456789012.dkr.ecr.ap-northeast-2.amazonaws.com/dev-monitoring-service-grafana:ci
LOKI_IMAGE=123456789012.dkr.ecr.ap-northeast-2.amazonaws.com/dev-monitoring-service-loki:ci
PROMTAIL_IMAGE=123456789012.dkr.ecr.ap-northeast-2.amazonaws.com/dev-monitoring-service-promtail:ci

PROMETHEUS_BIND_HOST=127.0.0.1
PROMETHEUS_PORT=9090
GRAFANA_BIND_HOST=127.0.0.1
GRAFANA_PORT=3005
LOKI_BIND_HOST=127.0.0.1
LOKI_PORT=3100

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=ci-grafana-admin-password

PROMETHEUS_RETENTION_TIME=7d
LOKI_RETENTION_PERIOD=168h
PROMETHEUS_CONFIG_FILE=monitoring/prometheus/prometheus.yml
PROMETHEUS_TARGET_FILE=monitoring/prometheus/targets/local-services.yml
LOKI_CONFIG_FILE=monitoring/loki/loki-config.yml
PROMTAIL_CONFIG_FILE=monitoring/promtail/promtail-config.yml

GRAFANA_AUTH_MYSQL_HOST=auth-mysql
GRAFANA_AUTH_MYSQL_PORT=3306
GRAFANA_AUTH_MYSQL_DATABASE=authdb
GRAFANA_AUTH_MYSQL_USER=authuser
GRAFANA_AUTH_MYSQL_PASSWORD=ci-auth-db-password

GRAFANA_USER_MYSQL_HOST=user-mysql
GRAFANA_USER_MYSQL_PORT=3306
GRAFANA_USER_MYSQL_DATABASE=user_service
GRAFANA_USER_MYSQL_USER=user_service
GRAFANA_USER_MYSQL_PASSWORD=ci-user-db-password

GRAFANA_EDITOR_MYSQL_HOST=editor-mysql
GRAFANA_EDITOR_MYSQL_PORT=3306
GRAFANA_EDITOR_MYSQL_DATABASE=documentsdb
GRAFANA_EDITOR_MYSQL_USER=documents
GRAFANA_EDITOR_MYSQL_PASSWORD=ci-editor-db-password

GRAFANA_AUTHZ_MYSQL_HOST=authz-mysql
GRAFANA_AUTHZ_MYSQL_PORT=3306
GRAFANA_AUTHZ_MYSQL_DATABASE=authz_service_db
GRAFANA_AUTHZ_MYSQL_USER=authz_user
GRAFANA_AUTHZ_MYSQL_PASSWORD=ci-authz-mysql-password
