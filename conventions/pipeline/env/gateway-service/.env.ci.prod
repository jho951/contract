SERVICE_SHARED_NETWORK=service-backbone-shared
BACKEND_SHARED_NETWORK=service-backbone-shared
MSA_SHARED_NETWORK=service-backbone-shared

GATEWAY_IMAGE=123456789012.dkr.ecr.ap-northeast-2.amazonaws.com/prod-gateway-service:ci

GATEWAY_HOST_BIND=127.0.0.1
GATEWAY_HOST_PORT=8080

APP_ENV=prod
APP_ENV_FILE=/app/.env.prod
GATEWAY_BIND=0.0.0.0
GATEWAY_PORT=8080
GATEWAY_REQUEST_TIMEOUT_MS=30000
GATEWAY_LOGIN_RATE_LIMIT_PER_MINUTE=20
GATEWAY_MAX_BODY_BYTES=1048576

AUTH_SERVICE_URL=http://auth-service:8081
AUTH_SERVICE_INTERNAL_REQUEST_SECRET=ci-auth-caller-proof-secret
USER_SERVICE_URL=http://user-service:8082
EDITOR_SERVICE_URL=http://editor-service:8083
AUTHZ_ADMIN_VERIFY_URL=http://authz-service:8084/permissions/internal/admin/verify

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=ci-redis-password
REDIS_TIMEOUT_MS=1000

GATEWAY_INTERNAL_JWT_SHARED_SECRET=ci-gateway-internal-jwt-secret
GATEWAY_INTERNAL_JWT_ISSUER=api-gateway
GATEWAY_INTERNAL_JWT_AUDIENCE=internal-services
GATEWAY_INTERNAL_JWT_TTL_SECONDS=300
GATEWAY_INTERNAL_REQUEST_SECRET=ci-shared-internal-secret

AUTHZ_INTERNAL_JWT_SECRET=ci-authz-caller-proof-secret
AUTHZ_INTERNAL_JWT_ISSUER=api-gateway
AUTHZ_INTERNAL_JWT_AUDIENCE=authz-service
AUTHZ_INTERNAL_JWT_TTL_SECONDS=300

AUTH_JWT_VERIFY_ENABLED=true
AUTH_JWT_SHARED_SECRET=ci-auth-access-jwt-secret
GATEWAY_FORWARD_AUTHORIZATION_HEADER=false

GATEWAY_SESSION_CACHE_ENABLED=true
GATEWAY_SESSION_LOCAL_CACHE_TTL_SECONDS=3
GATEWAY_SESSION_CACHE_TTL_SECONDS=60
GATEWAY_SESSION_CACHE_KEY_PREFIX=gateway:session:

GATEWAY_AUTHZ_CACHE_ENABLED=false
GATEWAY_AUTHZ_CACHE_TTL_SECONDS=300
GATEWAY_AUTHZ_CACHE_PREFIX=gateway:admin-authz:
GATEWAY_CORS_ALLOWED_ORIGINS=*

PLATFORM_SECURITY_AUTH_JWT_SECRET=ci-platform-security-jwt-secret
PLATFORM_SECURITY_IP_GUARD_ENABLED=true
PLATFORM_SECURITY_IP_GUARD_ADMIN_RULES_0=127.0.0.1/32
PLATFORM_SECURITY_IP_GUARD_ADMIN_RULES_1=10.0.0.0/8
PLATFORM_SECURITY_IP_GUARD_ADMIN_RULES_2=172.16.0.0/12
PLATFORM_SECURITY_IP_GUARD_ADMIN_RULES_3=192.168.0.0/16
PLATFORM_SECURITY_IP_GUARD_INTERNAL_RULES_0=127.0.0.1/32
PLATFORM_SECURITY_IP_GUARD_INTERNAL_RULES_1=10.0.0.0/8
PLATFORM_SECURITY_IP_GUARD_INTERNAL_RULES_2=172.16.0.0/12
PLATFORM_SECURITY_IP_GUARD_INTERNAL_RULES_3=192.168.0.0/16
