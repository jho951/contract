SERVICE_SHARED_NETWORK=service-backbone-shared
BACKEND_SHARED_NETWORK=service-backbone-shared
MSA_SHARED_NETWORK=service-backbone-shared

AUTHZ_SERVICE_IMAGE=123456789012.dkr.ecr.ap-northeast-2.amazonaws.com/prod-authz-service:replace-with-git-sha

AUTHZ_SERVICE_HOST_BIND=127.0.0.1
AUTHZ_SERVICE_HOST_PORT=8084

SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8084

AUTHZ_MYSQL_DATABASE=authz_service_db
AUTHZ_MYSQL_USER=authz_user
AUTHZ_MYSQL_PASSWORD=replace-with-authz-mysql-password
AUTHZ_MYSQL_ROOT_PASSWORD=replace-with-authz-mysql-root-password
AUTHZ_SPRING_DATASOURCE_URL=jdbc:mysql://authz-mysql:3306/authz_service_db?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
AUTHZ_SPRING_DATASOURCE_USERNAME=authz_user
AUTHZ_SPRING_DATASOURCE_PASSWORD=replace-with-authz-mysql-password
AUTHZ_SPRING_DATASOURCE_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver

PERMISSION_MYSQL_DATABASE=authz_service_db
PERMISSION_MYSQL_USER=authz_user
PERMISSION_MYSQL_PASSWORD=replace-with-authz-mysql-password
PERMISSION_MYSQL_ROOT_PASSWORD=replace-with-authz-mysql-root-password
PERMISSION_SPRING_DATASOURCE_URL=jdbc:mysql://authz-mysql:3306/authz_service_db?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
PERMISSION_SPRING_DATASOURCE_USERNAME=authz_user
PERMISSION_SPRING_DATASOURCE_PASSWORD=replace-with-authz-mysql-password

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TIMEOUT_MS=1000ms

AUTHZ_INTERNAL_JWT_SECRET=replace-with-authz-caller-proof-secret
AUTHZ_INTERNAL_JWT_ISSUER=api-gateway
AUTHZ_INTERNAL_JWT_AUDIENCE=authz-service

PERMISSION_INTERNAL_REQUEST_SECRET=replace-with-shared-internal-secret

PLATFORM_SECURITY_JWT_SECRET=replace-with-gateway-downstream-shared-secret
PLATFORM_SECURITY_JWT_ISSUER=api-gateway
PLATFORM_SECURITY_JWT_AUDIENCE=internal-services
PLATFORM_SECURITY_INTERNAL_ALLOW_CIDRS=127.0.0.1/32,172.16.0.0/12,10.0.0.0/8,192.168.0.0/16
AUTHZ_PLATFORM_GOVERNANCE_AUDIT_SERVICE_NAME=authz-service
AUTHZ_PLATFORM_GOVERNANCE_AUDIT_ENVIRONMENT=prod
AUTHZ_PLATFORM_SECURITY_SERVICE_ROLE_PRESET=INTERNAL_SERVICE
AUTHZ_PLATFORM_SECURITY_RATE_LIMIT_ENABLED=false
